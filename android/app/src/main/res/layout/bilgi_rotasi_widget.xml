<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_bg">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bilgi Rotası"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bugünkü durumun"
        android:textColor="#99FFFFFF"
        android:textSize="11sp"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/widget_energy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚡ Enerji: 50/50"
        android:textColor="#FFFF66"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="5dp" />

    <TextView
        android:id="@+id/widget_streak"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔥 Seri: 0 gün"
        android:textColor="#FFB347"
        android:textSize="13sp"
        android:layout_marginBottom="5dp" />

    <TextView
        android:id="@+id/widget_xp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⭐ XP: 0"
        android:textColor="#FFD700"
        android:textSize="13sp"
        android:layout_marginBottom="5dp" />

    <TextView
        android:id="@+id/widget_league"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🏆 Lig: Bronz"
        android:textColor="#00E5FF"
        android:textSize="13sp"
        android:layout_marginBottom="5dp" />

    <TextView
        android:id="@+id/widget_countdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="YKS: -- gün"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:layout_marginTop="8dp" />

</LinearLayout>